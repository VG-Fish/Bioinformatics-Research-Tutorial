# Install and initialize libraries
if (!requireNamespace("BiocManager", quietly = TRUE)) {
install.packages("BiocManager")
}
BiocManager::install()
BiocManager::install("DESeq2")
library(BiocManager)
library(DESeq2)
BiocManager::install("org.Mm.eg.db")
library(org.Mm.eg.db)
library(AnnotationDbi)
BiocManager::install("rtracklayer")
library(rtracklayer)
if (!requireNamespace("pheatmap", quietly = TRUE)) {
install.packages("pheatmap")
}
library(pheatmap)
library(grid)
if (!requireNamespace("ggplot2", quietly = TRUE)) {
install.packages("ggplot2")
}
if (!requireNamespace("ggrepel", quietly = TRUE)) {
install.packages("ggrepel")
}
library(ggplot2)
library(ggrepel)
# Go to core directory
core_directory <- "/Users/vishy/Documents/Bioinformatics Research/Mock_Project"
setwd(core_directory)
# Create and clean processed data directory
data_directory <- "Processed Data/"
dir.exists(data_directory) || dir.create(data_directory)
files <- list.files(data_directory, full.names = TRUE)
unlink(files, recursive = TRUE)
# Read gene counts
Counts <- read.delim("HISAT/gene_counts.csv", header=TRUE, row.names = 1, sep = ',')
Counts <- Counts[which(rowSums(Counts) > 50), ]
# Create core variables for downstream analysis
condition <- factor(c("S1","S2","S3","S1","S2","S3"))
group <- factor(c("ACOD","ACOD","ACOD","WTBM","WTBM","WTBM"))
coldata <- data.frame(
row.names = colnames(Counts),
condition = condition,
group = group
)
dds <- DESeqDataSetFromMatrix(countData = Counts, colData = coldata, design = ~condition + group)
dds <- DESeq(dds)
vsdata <- vst(dds, blind = FALSE)
vs_mat <- assay(vsdata)
write.csv(
vs_mat,
file = file.path(data_directory, "vst_transformed_counts.csv"),
quote = FALSE
)
pca_p <- plotPCA(vsdata, intgroup = "group")
png(file = file.path(data_directory, "pca_plot.png"), width = 1600, height = 1600, units = "px", res = 300)
pca_p
dev.off()
plotDispEsts(dds)
# Create pairwise comparison variables
res_S2_vs_S1 <- results(dds, contrast = c("condition", "S2", "S1"))
res_S3_vs_S1 <- results(dds, contrast = c("condition", "S3", "S1"))
sigs_S2_vs_S1 <- na.omit(res_S2_vs_S1)
sigs_S3_vs_S1 <- na.omit(res_S3_vs_S1)
sigs_S2_vs_S1 <- sigs_S2_vs_S1[sigs_S2_vs_S1$padj < 0.05,]
sigs_S3_vs_S1 <- sigs_S3_vs_S1[sigs_S3_vs_S1$padj < 0.05,]
all_results <- rbind(
data.frame(Comparison = "S2_vs_S1", sigs_S2_vs_S1),
data.frame(Comparison = "S3_vs_S1", sigs_S3_vs_S1)
)
# Map gene names to gene ids
all_results.df <- as.data.frame(all_results)
all_results.df$gene_name <- mapIds(
org.Mm.eg.db,
keys = rownames(all_results.df),
keytype = "ENSEMBL",
column = "SYMBOL",
multiVals = "first"
)
# Create gene expression column and write to file
all_results.df$diffexpressed <- "NO"
all_results.df$diffexpressed[all_results$log2FoldChange > 0.6 & all_results$pvalue < 0.05] <- "UP"
all_results.df$diffexpressed[all_results$log2FoldChange < -0.6 & all_results$pvalue < 0.05] <- "DOWN"
all_results_csv_save_path <- file.path(data_directory, "all_results_sigs.csv")
write.csv(all_results.df, file = all_results_csv_save_path)
# Import gene annotation file and process it for getting more details when mapping gene ids to gene names
gtf <- import("Genome_Info/Mus_musculus.GRCm39.111.gtf")
gtf_df <- as.data.frame(gtf)
gene_annot <- subset(gtf_df, type == "gene", select = c(gene_id, gene_name, gene_biotype))
gene_annot <- unique(gene_annot)
# Create separate data frame with mapped gene ids to extra gene information before saving to file.
pvals_df <- data.frame(
gene_id = rownames(all_results),
log2FoldChange = all_results$log2FoldChange,
pvalue = all_results$pvalue,
padj = all_results$padj,
stringsAsFactors = FALSE
)
pvals_annot <- merge(pvals_df, gene_annot, by = "gene_id", all.x = TRUE)
pvals_annot <- pvals_annot[, c(
"gene_id",
"gene_name",
"gene_biotype",
"log2FoldChange",
"pvalue",
"padj"
)]
pvals_annot_sorted <- pvals_annot[order(abs(pvals_annot$log2FoldChange), decreasing = TRUE), ]
pvals_annot_sorted <- na.omit(pvals_annot_sorted)
p_value_file_all_results <- file.path(data_directory, "all_results_DEGs_pvalues_annotated.txt")
write.table(
pvals_annot_sorted,
file = p_value_file_all_results,
sep = "\t",
quote = FALSE,
row.names = FALSE,
col.names = TRUE
)
# Get most commonly expressed genes across samples
top_genes_S2_vs_S1 <- rownames(sigs_S2_vs_S1)
top_genes_S3_vs_S1 <- rownames(sigs_S3_vs_S1)
common_top_genes <- Reduce(intersect, list(top_genes_S2_vs_S1, top_genes_S3_vs_S1))
# Create heatmaps of most commonly expressed genes across all samples
custom_order <- c("Test_Sample1", "Control_Sample1", "Test_Sample2", "Control_Sample2", "Test_Sample3", "Control_Sample3")
top_counts <- Counts[common_top_genes, custom_order]
hm <- pheatmap(
top_counts, scale = "row", show_rownames = FALSE, cluster_cols = FALSE,
annotation_colors = list(Condition = c("Sample1" = "red", "Sample2" = "green", "Sample3" = "blue")),
legend = TRUE, main = "Heatmap of DEGs"
)
png(file = file.path(data_directory, "heatmap_pairwiseDEGs.png"), width = 1600, height = 1600, units = "px", res = 300)
grid::grid.newpage()
grid::grid.draw(hm$gtable)
dev.off()
# Create dataframe to create the volcano plot, which showcases the most significant up- and down-regulated genes
diff_all_results_gnames <- read.csv(all_results_csv_save_path)
diff_all_results_gnames$diffexpressed <- "NO"
diff_all_results_gnames$diffexpressed[
diff_all_results_gnames$log2FoldChange > 0.6 & diff_all_results_gnames$pvalue < 0.05
] <- "UP"
diff_all_results_gnames$diffexpressed[
diff_all_results_gnames$log2FoldChange < -0.6 & diff_all_results_gnames$pvalue < 0.05
] <- "DOWN"
diff_all_results_valid_gnames <- na.omit(diff_all_results_gnames)
top10_gname_up <- head(
diff_all_results_valid_gnames[order(diff_all_results_valid_gnames$log2FoldChange, decreasing = TRUE), ], 10
)
top10_gname_down <- head(
diff_all_results_valid_gnames[order(diff_all_results_valid_gnames$log2FoldChange, decreasing = FALSE), ], 10
)
top_gnames <- c(top10_gname_up$gene_name, top10_gname_down$gene_name)
diff_all_results_gnames_subset <- subset(
diff_all_results_gnames,
gene_name %in% top_gnames & diffexpressed != "NO"
)
gname_volcano_p <- ggplot(data = diff_all_results_gnames, aes(x = log2FoldChange, y = -log10(pvalue), col = diffexpressed)) +
geom_point() +
scale_color_manual(values = c("NO" = "black", "UP" = "red", "DOWN" = "blue")) +
theme_minimal() +
geom_vline(xintercept = c(-0.6, 0.6), col = "red") +
geom_hline(yintercept = -log10(0.05), col = "red") +
theme(panel.grid = element_blank()) +
geom_text_repel(
data = diff_all_results_gnames_subset,
aes(label = gene_name),
box.padding = 0.6,
point.padding = 0.3,
max.overlaps = 20,
min.segment.length = 0
)
ggsave(
filename = file.path(data_directory, "top_gnames_volcano_plot.png"),
plot = gname_volcano_p,
width = 8, height = 6, dpi = 300
)
